{
  "id": "goodnight-m-flow",
  "name": "GoodNight M-Flow",
  "version": "1.0.0",
  "category": "knowledge",
  "source": {
    "type": "built-in",
    "upstream": {
      "inspiredBy": [
        "FlowElement-ai/m_flow"
      ]
    }
  },
  "capabilities": ["prompt"],
  "runtime": {
    "knowledgeMethod": "m-flow",
    "contextSection": "m_flow_paths",
    "visibleOutputs": [
      "_goodnight/outputs/m-flow/index.md",
      "_goodnight/outputs/m-flow/episodes/",
      "_goodnight/outputs/m-flow/paths/"
    ],
    "stateOutputs": [
      ".goodnight/m-flow/manifest.json",
      ".goodnight/m-flow/sources.json",
      ".goodnight/m-flow/episodes.json",
      ".goodnight/m-flow/facets.json",
      ".goodnight/m-flow/facet-points.json",
      ".goodnight/m-flow/entities.json",
      ".goodnight/m-flow/edges.json"
    ],
    "promptPolicy": "M-Flow runtime policy: start from native m-flow state plus rendered path artifacts, then answer through the lowest-cost evidence path. Preserve why the evidence is related before citing isolated facts."
  },
  "entry": {
    "prompt": "SKILL.md"
  },
  "support": {
    "built-in": "full",
    "codex": "partial",
    "claude": "partial"
  },
  "install": {
    "visibleByDefault": true,
    "enabledByDefault": true,
    "syncTargets": ["built-in", "codex", "claude"]
  },
  "reviewStatus": "reviewed",
  "riskFlags": []
}
